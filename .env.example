# ChatAI API (academic cloud)
CHATAI_API_KEY=YOUR_API_KEY
CHATAI_BASE_URL=https://chat-ai.academiccloud.de/v1
CHATAI_EMBEDDING_MODEL=e5-mistral-7b-instruct
CHATAI_LLM_MODEL=meta-llama-3.1-8b-instruct

# MDKeyChunker config (uses ChatAI as openai_compatible provider)
LLM_PROVIDER=chatai
LLM_BASE_URL=https://chat-ai.academiccloud.de/v1
LLM_MODEL=meta-llama-3.1-8b-instruct
MIN_CHUNK_SIZE=100
MAX_CHUNK_SIZE=1500
MERGE_BY_KEYS=true
MAX_MERGED_SIZE=3000

# Data directories
DATA_DIR=data
RAW_HTML_DIR=data/raw_html
PARSED_MD_DIR=data/parsed_mds
CHUNKS_DIR=data/mdkey_chunks
CHROMA_DIR=data/chroma_db
